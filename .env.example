# Copy to `.env` and fill in. `.env` is git-ignored ‚Äî NEVER commit real secrets.
# Tier-1 (the research loop) needs NONE of these ‚Äî it runs on the standard library.

# --- v1 web app: REQUIRED ---
# Chatbot LLM (Claude Haiku) + offline research-lab runs. Set a monthly spend cap in the console.
ANTHROPIC_API_KEY=

# --- v1 web app: backend (safe defaults; override as needed) ---
# QDRANT_URL=                               # unset = Qdrant local on-disk; set (+ QDRANT_API_KEY) = Qdrant Cloud
FRONTEND_ORIGIN=http://localhost:3000       # CORS: your frontend origin
RATE_LIMIT_PER_MIN=20                        # per-IP chat rate limit
DAILY_REQUEST_CAP=500                        # global daily chat request cap

# --- v1 web app: frontend ---
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# --- Tier-2 / Tier-3 (as services come online) ---
# LITELLM_MODEL=claude-sonnet-5
# LANGSMITH_API_KEY=
# LOGFIRE_TOKEN=
# AWS_REGION=ap-south-1
# CLERK_SECRET_KEY=                          # v2 auth only ‚Äî not needed in v1
